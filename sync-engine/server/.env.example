# ─────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────

# Port (Railway sets this automatically)
PORT=3000

# ─────────────────────────────────────────────────────────
# MongoDB (use MongoDB Atlas in production)
# Atlas URI format: mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# ─────────────────────────────────────────────────────────
MONGO_URI=mongodb://syncuser:syncpass@localhost:27017/syncengine?authSource=admin

# ─────────────────────────────────────────────────────────
# Redis (use Upstash in production)
# Upstash URI format: rediss://default:password@host.upstash.io:6379
# ─────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─────────────────────────────────────────────────────────
# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────
RATE_LIMIT_OPS_PER_SEC=30

# ─────────────────────────────────────────────────────────
# CORS (set to your Vercel frontend URL in production)
# Example: https://your-collab-app.vercel.app
# Use * to allow all origins (not recommended for production)
# ─────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*
